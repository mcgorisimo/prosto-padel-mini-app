# Git metadata
.git
.git/**
.gitignore
.gitattributes
.gitmodules

# Local environment files (tracked examples remain available)
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Dependencies and generated output
**/node_modules/
**/dist/
**/build/
**/coverage/
**/*.map

# Test artifacts
**/test-results/
**/playwright-report/
**/blob-report/
**/.playwright/
**/junit*.xml
**/*.lcov

# IDE and operating-system files
**/.idea/
**/.vscode/
**/*.swp
**/*.swo
**/.DS_Store
**/Thumbs.db
**/Desktop.ini

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Local database backups and dump archives
infra/test/backups/
**/*.dump
**/*.backup
**/*.bak
**/*.tar
**/*.gz
