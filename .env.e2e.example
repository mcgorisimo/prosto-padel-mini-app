# Copy to .env.e2e.local for live staging E2E.
# Do not commit .env.e2e.local.

E2E_TARGET=staging
E2E_SUPABASE_URL=https://your-staging-project-ref.supabase.co
E2E_SUPABASE_ANON_KEY=replace-with-staging-anon-key
E2E_SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-service-role-key
E2E_STAGING_PROJECT_REF=your-staging-project-ref
E2E_PRODUCTION_PROJECT_REF=your-production-project-ref
